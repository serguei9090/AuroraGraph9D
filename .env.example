# AuroraGraph9D Configuration

# Model Settings
# Which local Ollama model to use. Llama 3.1 8B is recommended for local reasoning.
AURA_MODEL="llama3.1:8b"

# Context Window Options
# Note: Ollama manages context length under the hood, but this setting is for documentation/awareness
# 8k, 32k, 128k, or 256k depending on your hardware limits
AURA_CONTEXT_WINDOW=256000

# FTS5 Retrieval Tuning
# The number of graph nodes/snippets to retrieve per query.
# Increase this from the default 15 to pull in massive amounts of context for complex cross-document aggregation.
FTS5_MATCH_LIMIT=50

# The number of words to grab from either side of the exact keyword match.
# 100 is good for tight snippets. Increase to 300+ to provide surrounding conversational context to the LLM.
# FTS5_SNIPPET_WORDS=300

#================================================
# Database Provider Settings
#================================================
# Choose between "sqlite" (default), "kuzu" (embedded graph), or "neo4j" (enterprise)
AURA_DB_PROVIDER="sqlite"

# SQLite database file location (default: auragraph_jit.db in the working dir)
# AURA_DB_PATH="./auragraph_jit.db"

# Kùzu Embedded Graph Database (used if AURA_DB_PROVIDER='kuzu')
KUZU_DB_PATH="./auragraph_graph"

# Neo4j Database Connection
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"

#================================================
# Performance Settings
#================================================
# Embedding device: "auto" (default) | "cpu" | "cuda" | "mps"
# "auto" → tries CUDA (NVIDIA) → MPS (Apple Silicon) → CPU in order.
# Override with "cpu" if you want to force CPU even when a GPU is present.
AURA_DEVICE="auto"

# Number of files to ingest in parallel.
# Set to 0 to use all available CPU cores.
# Default: 4 (a safe balance for most machines).
AURA_CONCURRENCY=4
